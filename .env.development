# 开发环境配置
# 使用说明：开发时先加载此环境变量，再启动后端
# PowerShell: $env:DATABASE_URL="postgresql://postgres:postgres@localhost:5434/crm_dev?schema=public"; npm run server
# CMD: set DATABASE_URL=postgresql://postgres:postgres@localhost:5434/crm_dev?schema=public && npm run server

DATABASE_URL="postgresql://postgres:postgres@localhost:5434/crm_dev?schema=public"
JWT_SECRET="dev-secret-do-not-use-in-production"
